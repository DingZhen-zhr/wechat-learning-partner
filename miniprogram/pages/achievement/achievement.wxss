.achievement-container {
  padding: 32rpx 16rpx 24rpx 16rpx;
  background: #f8f9fb;
  min-height: 100vh;
}

.summary-section {
  background: #fffbe7;
  border-radius: 28rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 16rpx #f5e7b6;
}
.summary-text {
  color: #b88a00;
  font-size: 38rpx;
  font-weight: bold;
}

.chart-section {
  background: #fff;
  border-radius: 28rpx;
  padding: 56rpx 40rpx;
  margin-bottom: 48rpx;
  box-shadow: 0 4rpx 16rpx #e6e6e6;
  min-height: 340rpx;
}
.chart-title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}
.bar-chart {
  display: flex;
  align-items: flex-end;
  height: 160rpx;
  margin-bottom: 24rpx;
}
.bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 0 10rpx;
}
.bar {
  width: 26rpx;
  background: linear-gradient(180deg, #ffb74d, #ff9800);
  border-radius: 12rpx 12rpx 0 0;
  transition: height 0.3s;
}
.bar-label {
  font-size: 26rpx;
  color: #888;
  margin-top: 10rpx;
}
.stat-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: #666;
  gap: 20rpx;
}
.stat-row text {
  white-space: nowrap;
}
.stat-value {
  color: #ff9800;
  font-weight: bold;
  font-size: 30rpx;
}

.badge-section {
  background: #fff;
  border-radius: 28rpx;
  padding: 56rpx 40rpx;
  box-shadow: 0 4rpx 16rpx #e6e6e6;
  min-height: 220rpx;
}
.badge-title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}
.badge-list {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
}
.badge-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.badge-img {
  width: 110rpx;
  height: 110rpx;
  margin-bottom: 12rpx;
}
.badge-desc {
  font-size: 28rpx;
  color: #4caf50;
  text-align: center;
  font-weight: 600;
}