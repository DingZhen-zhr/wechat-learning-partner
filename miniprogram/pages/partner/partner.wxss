/* pages/partner/partner.wxss */

/* === 1. 核心修复：全局盒模型设置 === */
/* 这段代码保证 padding 不会把宽度撑大 */
page {
  background-color: #f7f8fa;
  height: 100%;
  width: 100%;
  box-sizing: border-box; 
}

/* 让所有常用组件都继承盒模型 */
view, text, scroll-view, image, input, button {
  box-sizing: border-box;
}

.partner-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  width: 100%;
  overflow-x: hidden; /* 双重保险，禁止横向滚动 */
}

/* === 2. 聊天滚动区 === */
.chat-scroll-view {
  flex: 1;
  width: 100%;
  /* 这里的 padding 决定了聊天内容距离屏幕边缘的留白，30rpx 比较舒适 */
  padding: 20rpx 30rpx; 
  overflow-y: auto;
}

.chat-header-tip {
  text-align: center;
  margin: 20rpx 0 40rpx;
  width: 100%;
}

.chat-header-tip text {
  background-color: rgba(0, 0, 0, 0.05);
  color: #999;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

/* 消息项容器 */
.message-item {
  display: flex;
  margin-bottom: 30rpx;
  align-items: flex-start; /* 顶部对齐 */
  width: 100%; /* 占满内容区 */
}

/* 用户消息：WXML 已调整顺序，此处只需右对齐 */
.message-user {
  justify-content: flex-end; 
}

/* AI 消息：左对齐 */
.message-ai {
  justify-content: flex-start;
}

.avatar-box {
  width: 80rpx;
  height: 80rpx;
  flex-shrink: 0; /* 防止头像被压缩 */
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: #fff;
}

/* === 3. 气泡样式优化 === */
.bubble {
  /* 优化点：使用 calc 计算宽度，最大程度利用空间 */
  /* 屏幕宽 - 头像宽(80) - 间距(20) - 另一侧留白(约80，避免太满) */
  max-width: calc(100% - 160rpx); 
  padding: 22rpx 28rpx;
  font-size: 30rpx;
  line-height: 1.6;
  border-radius: 20rpx;
  position: relative;
  word-wrap: break-word; /* 英文自动换行 */
  word-break: break-all;
}

/* AI 气泡 */
.message-ai .bubble {
  background-color: #ffffff;
  color: #333;
  margin-left: 20rpx;
  border-top-left-radius: 4rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 用户气泡 */
.message-user .bubble {
  background-color: #007aff;
  color: #ffffff;
  margin-right: 20rpx;
  border-top-right-radius: 4rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 122, 255, 0.2);
}

/* 底部区域容器 */
.footer-area {
  width: 100%;
  background-color: #f7f8fa;
  padding-bottom: env(safe-area-inset-bottom); /* 适配全面屏底部 */
  border-top: 1rpx solid rgba(0,0,0,0.05);
}

/* === 4. 快捷指令 (Chips) === */
.quick-actions {
  width: 100%;
  white-space: nowrap; /* 必须：保证横向滚动 */
  padding: 20rpx 0 0 30rpx; /* 右边不加 padding，让内容看起来可以划出去 */
  height: 70rpx;
}

.chip {
  display: inline-block; /* 必须：配合 nowrap 实现横滑 */
  background-color: #fff;
  color: #007aff;
  border: 1rpx solid #007aff;
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  margin-right: 20rpx;
}

/* === 5. 输入框区域 === */
.input-bar {
  width: 100%;
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx 30rpx; /* 上 左右 下 */
}

.chat-input {
  flex: 1; /* 关键：自动占据剩余宽度 */
  background-color: #fff;
  height: 80rpx;
  border-radius: 40rpx;
  padding: 0 30rpx;
  font-size: 30rpx;
  margin-right: 20rpx; /* 与发送按钮的距离 */
}

.send-btn {
  width: 120rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background-color: #e0e0e0;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  flex-shrink: 0; /* 防止被压缩 */
  transition: all 0.3s;
}

.send-btn.active {
  background-color: #007aff;
}

.bottom-spacer {
  height: 40rpx;
}

/* 正在输入动画 */
.typing-bubble {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 40rpx;
  width: 80rpx;
}

.dot {
  width: 10rpx;
  height: 10rpx;
  background-color: #999;
  border-radius: 50%;
  margin: 0 4rpx;
  animation: typing 1.4s infinite ease-in-out both;
}

.dot1 { animation-delay: -0.32s; }
.dot2 { animation-delay: -0.16s; }

@keyframes typing {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}