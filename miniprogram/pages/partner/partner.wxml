<!-- pages/partner/partner.wxml -->
<view class="partner-container">
  
  <!-- 聊天内容滚动区域 -->
  <scroll-view 
    class="chat-scroll-view" 
    scroll-y="true" 
    scroll-into-view="{{scrollToView}}" 
    scroll-with-animation="true"
    bindtap="hideKeyboard"
  >
    <!-- 顶部提示语 -->
    <view class="chat-header-tip">
      <text>我是你的专属学习搭子，随时陪你聊天、打气！</text>
    </view>

    <!-- 消息列表 -->
    <block wx:for="{{msgList}}" wx:key="id">
      
      <!-- 情景一：用户发送的消息 (整体靠右：文字左 + 头像右) -->
      <view wx:if="{{item.role === 'user'}}" id="msg-{{index}}" class="message-item message-user">
        <!-- 1. 先写气泡 (显示在头像左边) -->
        <view class="bubble">
          <text user-select="true">{{item.content}}</text>
        </view>
        <!-- 2. 后写头像 (显示在最右边) -->
        <view class="avatar-box">
          <image class="avatar" src="/images/icons/user-default.png" mode="aspectFill"></image>
        </view>
      </view>

      <!-- 情景二：AI 回复的消息 (整体靠左：头像左 + 文字右) -->
      <view wx:else id="msg-{{index}}" class="message-item message-ai">
        <!-- 1. 先写头像 (显示在最左边) -->
        <view class="avatar-box">
          <image class="avatar" src="{{partnerAvatar}}" mode="aspectFill"></image>
        </view>
        <!-- 2. 后写气泡 (显示在头像右边) -->
        <view class="bubble">
          <text user-select="true">{{item.content}}</text>
        </view>
      </view>

    </block>

    <!-- AI 正在输入状态 (保持头像左，气泡右) -->
    <view class="message-item message-ai" wx:if="{{isAiTyping}}">
      <view class="avatar-box">
        <image class="avatar" src="{{partnerAvatar}}" mode="aspectFill"></image>
      </view>
      <view class="bubble typing-bubble">
        <view class="dot dot1"></view>
        <view class="dot dot2"></view>
        <view class="dot dot3"></view>
      </view>
    </view>

    <!-- 底部占位，防止内容被输入框遮挡 -->
    <view class="bottom-spacer"></view>
  </scroll-view>

  <!-- 底部操作区域 -->
  <view class="footer-area">
    <!-- 快捷指令 (Chips) -->
    <scroll-view class="quick-actions" scroll-x="true" enable-flex="true">
      <view class="chip" bindtap="sendQuickMsg" data-text="求鼓励！学习好累">😤 求鼓励</view>
      <view class="chip" bindtap="sendQuickMsg" data-text="帮我制定今天的复习计划">📅 制定计划</view>
      <view class="chip" bindtap="sendQuickMsg" data-text="讲个笑话放松一下">🤣 讲个笑话</view>
      <view class="chip" bindtap="sendQuickMsg" data-text="番茄工作法怎么用？">🍅 学习方法</view>
    </scroll-view>

    <!-- 输入框区域 -->
    <view class="input-bar">
      <input 
        class="chat-input" 
        value="{{inputValue}}" 
        placeholder="和搭子聊聊..." 
        confirm-type="send" 
        bindinput="onInput" 
        bindconfirm="handleSend"
        cursor-spacing="20"
      />
      <view class="send-btn {{inputValue.length > 0 ? 'active' : ''}}" bindtap="handleSend">
        发送
      </view>
    </view>
  </view>
</view>